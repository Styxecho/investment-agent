# --- 项目基础配置 ---
PROJECT_NAME=investment_agent
ENVIRONMENT=development

# --- 路径配置 (通常保持默认，利用代码自动解析绝对路径) ---
# 注意：这里不需要写具体路径，settings.py 会根据代码位置自动计算
# 如果需要覆盖，可以取消注释并修改
# DATA_EXTERNAL_ROOT=./data_external
# DATA_RUNTIME_ROOT=./data_runtime

# LLM 配置
# 请根据您本地实际安装的 Ollama 模型名称修改，例如 llama3.1:8b, qwen2.5:3b
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
USE_OLLAMA=true

# 数据库
DB_NAME=portfolio.db

# 同花顺账号 (可选，如果不想写在代码里)
IFIND_USERNAME=pazq1777
IFIND_PIN=951365

# --- 数据库配置 ---
DB_NAME=portfolio.db